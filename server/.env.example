PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL="postgresql://databundle:databundle_secret@localhost:5432/databundle?schema=public"

# Redis (sessions, JWT blacklist, caching)
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-this-to-a-long-random-secret-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_MAX=200

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Telecom API
TELECOM_API_URL=https://api.dataxpress.com/v1
TELECOM_API_KEY=your_telecom_api_key
TELECOM_MODE=mock

# GDPR
GDPR_REQUIRED=false

# Admin seed
ADMIN_EMAIL=admin@databundle.gh
ADMIN_PASSWORD=Admin@123456
